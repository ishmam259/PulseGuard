# ═══════════════════════════════════════
# PulseGuard AI — Environment Variables
# ═══════════════════════════════════════

# Database
DATABASE_URL=postgres://postgres:wirelight@localhost:5432/pulseguard

# JWT
JWT_SECRET=pulseguard_jwt_secret_change_in_production
JWT_REFRESH_SECRET=pulseguard_refresh_secret_change_in_production

# AI Worker
AI_WORKER_URL=http://localhost:8000

# Gemini (optional — leave empty for mock mode)
GEMINI_API_KEY=

# Server
PORT=5000
NODE_ENV=development
